<script>
window.YaGames = { init: function() {
  var sdk = {
    environment: { app:{id:'0'}, i18n:{lang:'en',tld:'com'}, browser:{lang:'en'}, payload:null },
    deviceInfo: { type:'desktop',
      isMobile:  function(){ return false; },
      isDesktop: function(){ return true;  },
      isTablet:  function(){ return false; },
      isTV:      function(){ return false; }
    },
    adv: {
      showFullscreenAdv: function(o){ if(o&&o.callbacks&&o.callbacks.onClose) o.callbacks.onClose(false); },
      showRewardedVideo: function(o){
        if(!o||!o.callbacks) return;
        if(o.callbacks.onOpen)     o.callbacks.onOpen();
        if(o.callbacks.onRewarded) o.callbacks.onRewarded();
        if(o.callbacks.onClose)    o.callbacks.onClose();
      },
      showBannerAdv:function(){},hideBannerAdv:function(){},
      getBannerAdvStatus:function(){ return Promise.resolve({stickyAdvIsShowing:false}); }
    },
    auth:     { openAuthDialog: function(){ return Promise.resolve(); } },
    feedback: {
      canReview:     function(){ return Promise.resolve({value:false}); },
      requestReview: function(){ return Promise.resolve({feedbackSent:false}); }
    },
    shortcut: {
      canShowPrompt: function(){ return Promise.resolve({canShow:false}); },
      showPrompt:    function(){ return Promise.resolve({outcome:'rejected'}); }
    },
    getPayments: function(){ return Promise.reject('no payments'); },
    getPlayer:   function(){ return Promise.resolve({
      isAuthorized:function(){return false;},getMode:function(){return 'lite';},
      getName:function(){return '';},getUniqueID:function(){return '0';},
      getPhoto:function(){return '';},getPayingStatus:function(){return 'unknown';},
      setData:function(){return Promise.resolve();},getData:function(){return Promise.resolve({});},
      getStats:function(){return Promise.resolve({});},setStats:function(){return Promise.resolve();}
    });},
    getFlags:   function(){ return Promise.resolve({}); },
    serverTime: function(){ return Promise.resolve(Date.now()); },
    on:         function(){},
    features: { LoadingAPI:{ready:function(){}}, GameplayAPI:{start:function(){},stop:function(){}} }
  };
  return Promise.resolve(sdk);
}};
</script>
<script>
(function(){ var s=document.createElement('script'); s.src='/sdk.js';
  s.onerror=function(){ console.warn('[Stub] sdk.js yuklenemedi'); };
  document.head.appendChild(s); })();
